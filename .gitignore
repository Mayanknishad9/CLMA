# 构建目录
build/
*.build/
*.xcodeproj/

# 编译输出
*.o
*.so
*.a
*.dylib
*.exe

# Python 编译缓存
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# 虚拟环境
venv/
.venv/
env/

# IDE文件
.vscode/
.idea/
*.swp
*.swo

# 依赖
deps/
third_party/

# 日志和缓存
*.log
*.cache

# 系统文件
.DS_Store
Thumbs.db

# API Key 配置（不提交真实密钥）
config/api_config.json

# 运行时数据
config/sessions/*
!config/sessions/.gitkeep
tools/sandbox/script_*
*.hermes/
flask_output.log

# 项目计划文档（非代码文件）
*.plan.md
implementation_plan.md
